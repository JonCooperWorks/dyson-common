{
  "name": "dyson-common-ui",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Shared React UI primitives + design tokens for dyson and dyson-swarm. Ships pre-built ESM (dist/) so consumers import plain JS over a git dependency.",
  "license": "MIT",
  "repository": "https://github.com/JonCooperWorks/dyson-common",
  "files": [
    "dist",
    "ui/tokens.css",
    "ui/components.css"
  ],
  "exports": {
    ".": "./dist/index.js",
    "./tokens.css": "./ui/tokens.css",
    "./components.css": "./ui/components.css"
  },
  "peerDependencies": {
    "react": ">=19"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^6.0.1",
    "esbuild": "^0.28.0",
    "jsdom": "^29.0.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "vitest": "^4.1.5"
  },
  "scripts": {
    "build": "esbuild ui/index.js --bundle --format=esm --jsx=transform --external:react --outfile=dist/index.js",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  }
}
